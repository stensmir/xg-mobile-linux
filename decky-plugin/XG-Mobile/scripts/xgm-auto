#!/bin/bash
# xgm-auto — Auto-detect XG Mobile and load nvidia only if connected.
#
# Called by systemd at boot (xg-mobile-auto.service).
# NEVER put nvidia in /etc/modules-load.d/ — this script handles it.
#
# Logic:
#   Boot → check egpu_connected sysfs → if 1 → activate + modprobe nvidia
#                                        if 0 → do nothing, AMD-only boot

SYSFS_CONNECTED="/sys/devices/platform/asus-nb-wmi/egpu_connected"
SYSFS_ENABLE="/sys/devices/platform/asus-nb-wmi/egpu_enable"
LOGFILE="/var/log/xgm-auto.log"

log() {
    echo "$(date '+%F %T') xgm-auto: $*" | tee -a "$LOGFILE"
}

case "${1:-start}" in
    start)
        if [ ! -f "$SYSFS_CONNECTED" ]; then
            log "asus-nb-wmi not loaded or sysfs not available. Skipping."
            exit 0
        fi

        CONNECTED=$(cat "$SYSFS_CONNECTED" 2>/dev/null)

        if [ "$CONNECTED" = "1" ]; then
            log "XG Mobile DETECTED. Activating eGPU..."

            # Step 1: ACPI activation
            echo 1 > "$SYSFS_ENABLE" 2>/dev/null
            log "egpu_enable = 1"

            # Step 2: PCIe rescan
            sleep 2
            echo 1 > /sys/bus/pci/rescan 2>/dev/null
            log "PCIe rescan done"

            # Step 3: Load nvidia driver (NO nvidia-drm — it steals DRM minor 0
            # from amdgpu and crashes gamescope. Games use DXVK/Vulkan directly.)
            sleep 2
            modprobe nvidia 2>/dev/null
            modprobe nvidia-uvm 2>/dev/null
            modprobe nvidia-drm modeset=1 2>/dev/null  # blacklisted at boot, but games need it
            log "nvidia modules loaded (nvidia-drm loaded at runtime, blacklisted at boot)"

            # Step 4: Verify via sysfs (nvidia-smi needs nvidia-utils, may not be installed)
            sleep 2
            GPU_ON_BUS=0
            for dev in /sys/bus/pci/devices/*; do
                vendor=$(cat "$dev/vendor" 2>/dev/null)
                if [ "$vendor" = "0x10de" ]; then
                    GPU_ON_BUS=1
                    break
                fi
            done
            if [ "$GPU_ON_BUS" = "1" ]; then
                log "SUCCESS: NVIDIA GPU on PCIe bus"
            else
                log "WARNING: GPU not found on PCIe bus"
            fi
        else
            log "XG Mobile NOT connected. AMD-only boot. nvidia not loaded."
        fi
        ;;

    stop)
        # Safe removal: PCIe remove first, then modprobe -r, then ACPI disable
        log "Stopping eGPU..."

        # PCIe remove all nvidia devices (frees driver even if refcount > 0)
        for dev in /sys/bus/pci/devices/*; do
            vendor=$(cat "$dev/vendor" 2>/dev/null)
            if [ "$vendor" = "0x10de" ]; then
                bdf=$(basename "$dev")
                log "Removing PCIe device $bdf"
                echo 1 > "$dev/remove" 2>/dev/null
            fi
        done

        # Now try unloading modules (should succeed after PCIe remove)
        if lsmod | grep -q "^nvidia"; then
            modprobe -r nvidia-uvm nvidia-drm nvidia-modeset nvidia 2>/dev/null
            if lsmod | grep -q "^nvidia"; then
                log "WARN: nvidia modules still loaded (non-critical)"
            else
                log "nvidia modules unloaded"
            fi
        fi

        if [ -f "$SYSFS_ENABLE" ]; then
            echo 0 > "$SYSFS_ENABLE" 2>/dev/null
            log "egpu_enable = 0"
        fi
        ;;

    *)
        echo "Usage: xgm-auto [start|stop]"
        exit 1
        ;;
esac
