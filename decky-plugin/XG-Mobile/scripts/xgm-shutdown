#!/bin/bash
# xgm-shutdown — Safe eGPU teardown on reboot/shutdown.
# PCIe remove → modprobe -r (nvidia only) → ACPI disable.

SYSFS_ENABLE="/sys/devices/platform/asus-nb-wmi/egpu_enable"
VENDOR_FILE="/home/deck/.config/xgm/vendor"
LOGFILE="/var/log/xgm-shutdown.log"

log() { echo "$(date '+%F %T') xgm-shutdown: $*" | tee -a "$LOGFILE"; }

# Vendor (default nvidia for backward compat)
VENDOR=nvidia
if [ -r "$VENDOR_FILE" ]; then
    v=$(tr -d '[:space:]' < "$VENDOR_FILE")
    case "$v" in
        nvidia|amd) VENDOR="$v" ;;
    esac
fi

if [ "$VENDOR" = "nvidia" ]; then
    REMOVE_VENDOR="0x10de"
else
    REMOVE_VENDOR="0x1002"
fi

# Step 1: PCIe-remove dock GPU(s). Skip 0000:09:* (integrated AMD iGPU).
for dev in /sys/bus/pci/devices/*; do
    vendor=$(cat "$dev/vendor" 2>/dev/null)
    bdf=$(basename "$dev")
    if [ "$vendor" = "$REMOVE_VENDOR" ] && [[ "$bdf" != 0000:09:* ]]; then
        log "Removing PCIe device $bdf"
        echo 1 > "$dev/remove" 2>/dev/null
    fi
done

# Step 2 (nvidia only): unload modules.
# AMD: amdgpu releases cleanly on PCIe remove, no modprobe -r needed.
if [ "$VENDOR" = "nvidia" ] && lsmod | grep -q "^nvidia"; then
    modprobe -r nvidia-uvm nvidia-drm nvidia-modeset nvidia 2>/dev/null
    if lsmod | grep -q "^nvidia"; then
        log "WARN: nvidia modules still loaded (non-critical, PCIe device already removed)"
    else
        log "nvidia modules unloaded"
    fi
fi

# Step 3: ACPI disable — cut power to the dock (universal)
if [ -f "$SYSFS_ENABLE" ]; then
    echo 0 > "$SYSFS_ENABLE" 2>/dev/null
    log "egpu_enable = 0 (dock powered off)"
fi

log "Shutdown cleanup complete (vendor=$VENDOR)"
